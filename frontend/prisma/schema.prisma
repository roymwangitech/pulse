generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  displayName  String?
  passwordHash String
  avatarUrl    String
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)
  postingBlocked Boolean  @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  posts          Post[]
  threadReplies  ThreadReply[]
  reactions      Reaction[]
  replyReactions ReplyReaction[]
  refreshTokens  RefreshToken[]
  conversationsA Conversation[]  @relation("ConvUserA")
  conversationsB Conversation[]  @relation("ConvUserB")
  sentMessages   DirectMessage[] @relation("MsgSender")

  @@index([username])
  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Post {
  id         String   @id @default(cuid())
  userId     String
  caption    String
  imageUrl   String?
  searchText String?
  pinned     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashtags  PostHashtag[]
  reactions Reaction[]
  replies   ThreadReply[]

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@index([searchText])
  @@index([pinned])
}

model ThreadReply {
  id            String   @id @default(cuid())
  postId        String
  parentReplyId String?
  userId        String
  content       String
  imageUrl      String?
  depth         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  post         Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentReply  ThreadReply?    @relation("ReplyThread", fields: [parentReplyId], references: [id], onDelete: Cascade)
  childReplies ThreadReply[]   @relation("ReplyThread")
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions    ReplyReaction[]

  @@index([postId])
  @@index([parentReplyId])
  @@index([createdAt])
}

model Reaction {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  emoji     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, emoji])
  @@index([postId])
}

model ReplyReaction {
  id        String   @id @default(cuid())
  userId    String
  replyId   String
  emoji     String
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply ThreadReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, replyId, emoji])
  @@index([replyId])
}

model Hashtag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  posts PostHashtag[]

  @@index([name])
}

model PostHashtag {
  postId    String
  hashtagId String

  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@id([postId, hashtagId])
  @@index([hashtagId])
}

// Direct messaging — space-efficient design
model Conversation {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userA    User            @relation("ConvUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User            @relation("ConvUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages DirectMessage[]

  // Ensure only one conversation per pair (userAId < userBId enforced in app logic)
  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([updatedAt(sort: Desc)])
}

model DirectMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String   @db.VarChar(3000)
  replyToId      String?
  readAt         DateTime?
  deletedBySender   Boolean @default(false)
  deletedByReceiver Boolean @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User          @relation("MsgSender", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo      DirectMessage? @relation("MsgReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      DirectMessage[] @relation("MsgReply")

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
}
