# Neon PostgreSQL connection string
# Get yours at https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/pulsechat?sslmode=require"

# Server
PORT=4000
NODE_ENV=development

# JWT Secrets (generate strong random strings for production)
JWT_ACCESS_SECRET=your-super-secret-access-key-change-me
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# File uploads (local storage)
UPLOAD_DIR=uploads
UPLOAD_BASE_URL=http://localhost:4000/uploads
MAX_FILE_SIZE=10485760
STORAGE_PROVIDER=local

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Future cloud storage (uncomment when ready)
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=pulsechat-uploads
