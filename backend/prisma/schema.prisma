generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum StickerCategory {
  MEMES
  REACTIONS
  GAMING
  ANIME
  ANIMALS
  RANDOM_FUN
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  displayName  String?
  passwordHash String
  avatarUrl    String
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  posts         Post[]
  threadReplies ThreadReply[]
  reactions     Reaction[]
  replyReactions ReplyReaction[]
  refreshTokens RefreshToken[]

  @@index([username])
  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Post {
  id         String   @id @default(cuid())
  userId     String
  imageUrl   String?
  stickerUrl String?
  caption    String?
  searchText String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashtags  PostHashtag[]
  reactions Reaction[]
  replies   ThreadReply[]

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@index([searchText])
}

model ThreadReply {
  id            String   @id @default(cuid())
  postId        String
  parentReplyId String?
  userId        String
  content       String?
  imageUrl      String?
  stickerUrl    String?
  depth         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  post         Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentReply  ThreadReply?    @relation("ReplyThread", fields: [parentReplyId], references: [id], onDelete: Cascade)
  childReplies ThreadReply[]   @relation("ReplyThread")
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions    ReplyReaction[]

  @@index([postId])
  @@index([parentReplyId])
  @@index([createdAt])
}

model Reaction {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  emoji     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, emoji])
  @@index([postId])
}

model ReplyReaction {
  id        String   @id @default(cuid())
  userId    String
  replyId   String
  emoji     String
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply ThreadReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, replyId, emoji])
  @@index([replyId])
}

model Hashtag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  posts PostHashtag[]

  @@index([name])
}

model PostHashtag {
  postId    String
  hashtagId String

  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@id([postId, hashtagId])
  @@index([hashtagId])
}

model Sticker {
  id        String          @id @default(cuid())
  name      String
  url       String
  category  StickerCategory
  createdAt DateTime        @default(now())

  @@index([category])
}
